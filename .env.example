# =============================================
# InversorPro — Variables de Entorno
# Copiar como .env y completar los valores
# =============================================

PORT=3000
NODE_ENV=development

# --- Login (cambiar antes de usar en producción) ---
LOGIN_USERNAME=admin
LOGIN_PASSWORD=inversorpro123
JWT_SECRET=cambiar_este_secreto_por_uno_aleatorio_largo

# --- Caché (minutos) ---
CACHE_TTL_MINUTES=5

# --- APIs Opcionales de mercado ---
# CoinGecko Pro (el tier gratuito funciona sin key)
COINGECKO_API_KEY=

# Alpha Vantage — acciones US (gratis en alphavantage.co)
ALPHA_VANTAGE_KEY=

# Reddit OAuth2 — sentimiento de mercado (app tipo "script", gratis en reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Etherscan — wallets cripto (gratis en etherscan.io)
ETHERSCAN_API_KEY=

# --- Bot de Telegram ---
# 1. Hablar con @BotFather en Telegram → /newbot → copiar el token
TELEGRAM_BOT_TOKEN=

# 2. Abrir t.me/userinfobot → copiar tu chat_id numérico
#    Para múltiples destinatarios, separar con comas: 123456,789012
TELEGRAM_CHAT_IDS=

# --- Alertas automáticas (thresholds) ---
# Enviar alerta de arbitraje cuando la ganancia neta supere este %
ARBITRAGE_ALERT_THRESHOLD=1.5

# Enviar alerta de señal cuando el score supere este valor (0 a 1)
SIGNAL_ALERT_THRESHOLD=0.5

# Enviar alerta de Fear & Greed en zonas extremas
FEAR_GREED_ALERT_LOW=20
FEAR_GREED_ALERT_HIGH=80
